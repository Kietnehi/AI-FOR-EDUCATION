# General
# Ignore Python bytecode caches, virtual envs, editor and OS files
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build / distribution
build/
dist/
*.egg-info/

# Node
frontend/node_modules/
frontend/.next/
frontend/tsconfig.tsbuildinfo
frontend/build.log

# Storage directories (repo-specific)
backend/storage/chroma/
backend/storage/uploads/*
backend/storage/generated/*
backend/storage/notebooklm/
backend/storage/extracted/
!backend/storage/uploads/.gitkeep
!backend/storage/generated/.gitkeep
!backend/storage/images/.gitkeep

# Environment files
*.env
frontend/.env.local
backend/.env

# IDEs / editors
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
*.mp4

# GitHub
.github/copilot-instructions.md
     