backend/storage/extracted/*
!backend/storage/extracted/.gitkeep
backend/storage/images/*
!backend/storage/images/.gitkeep
backend/storage/notebooklm/*
!backend/storage/notebooklm/.gitkeep
backend/storage/outputs/*
!backend/storage/outputs/.gitkeep

# --- Environment Files ---
.env
.env.*
!.env.example
!.env.docker.example
cookie.txt
backend/.env
frontend/.env.local

