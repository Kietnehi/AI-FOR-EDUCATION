# Copy this file to .env before running docker compose.
# Replace placeholders with your own credentials where needed.

# --- GLOBAL SETTINGS ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# --- DATABASE ---
# Use Atlas URI for production or remote DB
MONGO_URI=mongodb://mongo:27017/your_db_name
MONGO_DB_NAME=ai_learning_platform

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- AI PROVIDERS & MODELS ---
LLM_PROVIDER=gemini

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_GUARDRAIL_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEYS=["your_gemini_api_key_here"]
GEMINI_MODEL=gemini-3-flash-preview

# Mascot & Web Search
MASCOT_CHAT_MODEL=openai/gpt-4o-mini
TAVILY_API_KEY=your_tavily_api_key_here
WEB_SEARCH_REFINEMENT_MODEL=openai/gpt-4o-mini

# Speech-to-Text (Local Whisper or Groq)
WHISPER_MODEL=base
WHISPER_LANGUAGE=
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Others
PEXELS_API_KEY=your_pexels_api_key_here
OPENROUTER_SITE_URL=https://your-domain.example.com
OPENROUTER_SITE_NAME=your_app_name_here

# --- RAG & CHUNKING ---
CHROMA_COLLECTION_NAME=material_chunks
CHUNK_SIZE=2500
CHUNK_OVERLAP=500
RETRIEVAL_TOP_K=6
CHAT_MEMORY_TURNS=8
MASCOT_MEMORY_TURNS=10
MATERIAL_GUARDRAIL_EXCERPT_CHARS=12000

# --- NOTEBOOKLM (VIDEO/INFOGRAPHIC GENERATION) ---
NOTEBOOKLM_GENERATE_WAIT_SECONDS=120
NOTEBOOKLM_HEADLESS=false

# --- OBJECT STORAGE (MINIO / CLOUDFLARE R2) ---
USE_OBJECT_STORAGE=true
USE_R2=false
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=your_minio_user_here
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_BUCKET=your_bucket_name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET=your_r2_bucket_name
R2_PUBLIC_BASE_URL=https://cdn.example.com

# --- DOCKER HOT-RELOAD (WINDOWS/WSL2 OPTIMIZATION) ---
CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=500
WATCHPACK_POLLING=true
WATCHFILES_FORCE_POLLING=true

# --- FRONTEND ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_HOST=http://localhost:8000
WARMUP_ROUTES_ON_START=1
