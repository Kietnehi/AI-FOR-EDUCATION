# Copy this file to .env before running docker compose.
# Fill API keys you need; empty keys are allowed if those providers are not used.

APP_ENV=development
LOG_LEVEL=INFO

# Database
MONGO_URI=mongodb://mongo:27017/ai_learning_platform
MONGO_DB_NAME=ai_learning_platform

# AI providers
LLM_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_GUARDRAIL_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

GEMINI_API_KEY=
GEMINI_API_KEYS=[]
GEMINI_MODEL=gemini-3-flash-preview
MASCOT_CHAT_MODEL=openai/gpt-4o-mini

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
WHISPER_MODEL=base

OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=
PEXELS_API_KEY=

CHROMA_COLLECTION_NAME=material_chunks
CHUNK_SIZE=2500
CHUNK_OVERLAP=500
RETRIEVAL_TOP_K=6
CHAT_MEMORY_TURNS=8
MASCOT_MEMORY_TURNS=10
MATERIAL_GUARDRAIL_EXCERPT_CHARS=12000

# Public API URL for frontend if you run frontend outside compose
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_HOST=http://localhost:8000
