# Copy this file to .env before running docker compose.
# Fill API keys you need; empty keys are allowed if those providers are not used.

# --- GLOBAL SETTINGS ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# --- DATABASE ---
# Use Atlas URI for production or remote DB
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/dbname
# Use local container URI (default in compose)
MONGO_URI=mongodb://mongo:27017/ai_learning_platform
MONGO_DB_NAME=ai_learning_platform

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- AI PROVIDERS & MODELS ---
LLM_PROVIDER=gemini  # Options: gemini, openai

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_GUARDRAIL_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini Configuration
GEMINI_API_KEY=
GEMINI_API_KEYS=[]  # Support rotation: ["key1", "key2"]
GEMINI_MODEL=gemini-3-flash-preview

# Mascot & Web Search
MASCOT_CHAT_MODEL=openai/gpt-4o-mini
TAVILY_API_KEY=
WEB_SEARCH_REFINEMENT_MODEL=openai/gpt-4o-mini

# Speech-to-Text (Local Whisper or Groq)
WHISPER_MODEL=base
WHISPER_LANGUAGE=
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Others
PEXELS_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# --- RAG & CHUNKING ---
CHROMA_COLLECTION_NAME=material_chunks
CHUNK_SIZE=2500
CHUNK_OVERLAP=500
RETRIEVAL_TOP_K=6
CHAT_MEMORY_TURNS=8
MASCOT_MEMORY_TURNS=10
MATERIAL_GUARDRAIL_EXCERPT_CHARS=12000

# --- NOTEBOOKLM (VIDEO/INFOGRAPHIC GENERATION) ---
NOTEBOOKLM_GENERATE_WAIT_SECONDS=120
NOTEBOOKLM_HEADLESS=false

# --- OBJECT STORAGE (MINIO / CLOUDFLARE R2) ---
USE_R2=false
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=ai-learning-storage
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# --- DOCKER HOT-RELOAD (WINDOWS/WSL2 OPTIMIZATION) ---
# Set to true to enable polling if changes are not detected immediately
CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=500
WATCHPACK_POLLING=true
WATCHFILES_FORCE_POLLING=true

# --- FRONTEND ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_HOST=http://localhost:8000
WARMUP_ROUTES_ON_START=1
