# =========================
# Docker Compose Runtime
# =========================

# App mode
APP_ENV=development
LOG_LEVEL=INFO

# Ports mapping to host
FRONTEND_PORT=3000
BACKEND_PORT=8000
MONGO_PORT=27017

# MongoDB container credentials
# Atlas URI (đang dùng)
MONGO_URI=mongodb+srv://your_user:your_password@your-cluster.mongodb.net/your_db_name

# Local MongoDB fallback (chỉ dùng khi bật profile local-db)
MONGO_ROOT_USERNAME=your_mongo_root_username_here
MONGO_ROOT_PASSWORD=your_mongo_root_password_here
MONGO_DB_NAME=ai_learning_platform

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_RESULT_EXPIRES_SECONDS=86400
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=1800
CELERY_TASK_TIME_LIMIT_SECONDS=2100
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# Frontend -> Backend API (client browser calls)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_HOST=http://localhost:8000

# CORS for backend (JSON array string)
CORS_ORIGINS=["http://localhost:3000"]

# Vector/chunking tuning
CHROMA_COLLECTION_NAME=material_chunks
CHUNK_SIZE=2500
CHUNK_OVERLAP=500
RETRIEVAL_TOP_K=6
MATERIAL_GUARDRAIL_EXCERPT_CHARS=12000
CHAT_MEMORY_TURNS=8
MASCOT_MEMORY_TURNS=10

# LLM provider config
LLM_PROVIDER=gemini

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_GUARDRAIL_MODEL=openai/gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter (optional)
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=your_app_name_here

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEYS=["your_gemini_api_key_here"]
GEMINI_MODEL=gemini-3-flash-preview
MASCOT_CHAT_MODEL=openai/gpt-4o-mini

# Speech / STT
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
WHISPER_MODEL=base
WHISPER_SMALL_MODEL=small
WHISPER_LANGUAGE=

# NotebookLM automation
NOTEBOOKLM_HEADLESS=true
NOTEBOOKLM_GENERATE_WAIT_SECONDS=120

# OCR.Space for image material upload
OCR_SPACE_API_KEY=your_ocr_space_api_key_here
OCR_SPACE_URL=https://api.ocr.space/parse/image
OCR_SPACE_TIMEOUT_SECONDS=120
OCR_SPACE_LAYOUT_ENGINE=3
OCR_SPACE_BOXES_ENGINE=2

# Object Storage (MinIO dev / Cloudflare R2 prod)
USE_OBJECT_STORAGE=true
USE_R2=true
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=your_minio_user_here
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_BUCKET=your_bucket_name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET=your_r2_bucket_name
R2_PUBLIC_BASE_URL=

# Auth (Google OAuth + JWT)
GOOGLE_CLIENT_ID=your_google_client_id_here
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=43200
AUTH_COOKIE_NAME=ai_learning_auth_token
AUTH_COOKIE_SECURE=false

# --- FRONTEND CONFIGURATION ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_HOST=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_app_password_here
CONTACT_RECIPIENT_EMAIL=your_contact_email@example.com
