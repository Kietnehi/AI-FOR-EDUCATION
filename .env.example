# =========================
# AI For Education - Env Example (Root)
# =========================

# --- APP MODE ---
APP_ENV=development
LOG_LEVEL=INFO

# --- PORTS (Docker) ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
MONGO_PORT=27017

# --- DATABASE (MongoDB) ---
# Dùng Atlas URI hoặc Local URI
MONGO_URI=mongodb://mongo:27017/ai_learning_platform
MONGO_DB_NAME=ai_learning_platform
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=

# --- REDIS / CELERY ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- VECTOR STORE / CHUNKING ---
CHROMA_COLLECTION_NAME=material_chunks
CHUNK_SIZE=2500
CHUNK_OVERLAP=500
RETRIEVAL_TOP_K=6
MATERIAL_GUARDRAIL_EXCERPT_CHARS=12000
CHAT_MEMORY_TURNS=8
MASCOT_MEMORY_TURNS=10

# --- AI PROVIDERS & MODELS ---
LLM_PROVIDER=gemini  # Options: gemini, openai

# OpenAI / OpenRouter
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_GUARDRAIL_MODEL=openai/gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=AIMENTOR

# Gemini
GEMINI_API_KEY=
GEMINI_API_KEYS=[]
GEMINI_MODEL=gemini-3-flash-preview
MASCOT_CHAT_MODEL=openai/gpt-4o-mini

# --- SPEECH / STT ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
WHISPER_MODEL=base
WHISPER_SMALL_MODEL=small
WHISPER_LANGUAGE=

# --- NOTEBOOKLM AUTOMATION ---
NOTEBOOKLM_HEADLESS=true
NOTEBOOKLM_GENERATE_WAIT_SECONDS=120

# --- OBJECT STORAGE (MinIO / Cloudflare R2) ---
USE_OBJECT_STORAGE=false
USE_R2=false
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=ai-learning-storage
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# --- AUTH (Google OAuth + JWT) ---
GOOGLE_CLIENT_ID=
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=43200
AUTH_COOKIE_NAME=ai_learning_auth_token
AUTH_COOKIE_SECURE=false

# --- FRONTEND CONFIGURATION ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_HOST=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- CONTACT EMAIL ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
CONTACT_RECIPIENT_EMAIL=
TURNSTILE_SECRET_KEY=

# --- CORS & SECURITY ---
CORS_ORIGINS=["http://localhost:3000"]
