# --- BACKEND CONFIGURATION ---
APP_ENV=development
LOG_LEVEL=INFO

# Database - MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=<app-name>
MONGO_DB_NAME=ai_learning_platform

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Vector Store - ChromaDB
CHROMA_PERSIST_DIR=./backend/storage/chroma
CHROMA_COLLECTION_NAME=material_chunks

# AI Providers & Models
LLM_PROVIDER=gemini
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_GUARDRAIL_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1
# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
# Groq & Speech
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com
WHISPER_MODEL=base

# OpenRouter (Optional)
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# File Storage
UPLOAD_DIR=./backend/storage/uploads
GENERATED_DIR=./backend/storage/generated

# Object Storage
USE_OBJECT_STORAGE=false
# MinIO (development) / S3 (production)
USE_S3=false
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=ai-learning-storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# Processing Settings
CHUNK_SIZE=2500
CHUNK_OVERLAP=500
RETRIEVAL_TOP_K=6
MATERIAL_GUARDRAIL_EXCERPT_CHARS=12000
CORS_ORIGINS=["http://localhost:3000"]

# --- FRONTEND CONFIGURATION ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_HOST=http://localhost:8000
