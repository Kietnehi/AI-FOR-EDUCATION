# Docker image settings
DOCKERHUB_NAMESPACE=your-dockerhub-username
IMAGE_TAG=latest

# Tunnel
CLOUDFLARED_TUNNEL_TOKEN=

# Runtime mode
APP_ENV=production
LOG_LEVEL=INFO

# API URLs exposed by your Named Tunnel hostnames
NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.com/api
NEXT_PUBLIC_API_HOST=https://api.your-domain.com
CORS_ORIGINS=["https://app.your-domain.com"]

# Auth and security
JWT_SECRET_KEY=replace_with_strong_secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=43200
AUTH_COOKIE_NAME=ai_learning_auth_token
AUTH_COOKIE_SECURE=true
GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# SMTP/contact
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
CONTACT_RECIPIENT_EMAIL=your_contact_receiver_email

# Datastores
MONGO_URI=your_mongodb_connection_string
MONGO_DB_NAME=ai_learning_platform
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# LLM providers
LLM_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_GUARDRAIL_MODEL=openai/gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://openrouter.ai/api/v1
GEMINI_API_KEY=
GEMINI_API_KEYS=[]
GEMINI_MODEL=gemini-3-flash-preview
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
WHISPER_MODEL=base
WHISPER_LANGUAGE=
PEXELS_API_KEY=

# Storage
USE_OBJECT_STORAGE=true
USE_R2=true
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=ai-learning-storage
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# RAG tuning
CHROMA_COLLECTION_NAME=material_chunks
CHUNK_SIZE=2500
CHUNK_OVERLAP=500
RETRIEVAL_TOP_K=6
MATERIAL_GUARDRAIL_EXCERPT_CHARS=12000
CHAT_MEMORY_TURNS=8
MASCOT_MEMORY_TURNS=10
NOTEBOOKLM_HEADLESS=true
NOTEBOOKLM_GENERATE_WAIT_SECONDS=120
