# ==========================================
# Backend Configuration - Environment Example
# ==========================================

APP_ENV=development
LOG_LEVEL=INFO

# --- Database - MongoDB ---
# Dùng Atlas URI hoặc Local URI
MONGO_URI=mongodb://localhost:27017/ai_learning_platform
MONGO_DB_NAME=ai_learning_platform

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Vector Store - ChromaDB ---
CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION_NAME=material_chunks

# --- AI Providers & Models ---
LLM_PROVIDER=gemini  # gemini, openai

# OpenAI / OpenRouter
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=AIMENTOR

# Gemini
GEMINI_API_KEY=
GEMINI_API_KEYS=[]
GEMINI_MODEL=gemini-3-flash-preview
MASCOT_CHAT_MODEL=openai/gpt-4o-mini
WEB_SEARCH_REFINEMENT_MODEL=openai/gpt-4o-mini

# --- Web Search ---
# Tavily API Key: Lấy từ https://app.tavily.com
TAVILY_API_KEY=

# --- File Storage ---
UPLOAD_DIR=./storage/uploads
GENERATED_DIR=./storage/generated
IMAGE_CACHE_DIR=./storage/images

# Object Storage (MinIO / Cloudflare R2)
USE_OBJECT_STORAGE=false
USE_R2=false
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=ai-learning-storage
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# --- External APIs ---
PEXELS_API_KEY=

# --- CORS & Security ---
CORS_ORIGINS=["http://localhost:3000"]

# --- RAG & Processing Settings ---
CHUNK_SIZE=2500
CHUNK_OVERLAP=500
RETRIEVAL_TOP_K=6
CHAT_MEMORY_TURNS=8
MASCOT_MEMORY_TURNS=10
MATERIAL_GUARDRAIL_EXCERPT_CHARS=12000

# --- Speech / STT ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
WHISPER_MODEL=base
WHISPER_SMALL_MODEL=small

# --- Auth (Google OAuth + JWT) ---
GOOGLE_CLIENT_ID=
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=43200
AUTH_COOKIE_NAME=ai_learning_auth_token
AUTH_COOKIE_SECURE=false

# Cloudflare Turnstile CAPTCHA (Backend Secret)
TURNSTILE_SECRET_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
CONTACT_RECIPIENT_EMAIL=

# --- Shared Frontend Config (For references) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_HOST=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
