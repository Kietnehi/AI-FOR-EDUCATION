APP_ENV=development
LOG_LEVEL=INFO

MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=<app-name>
MONGO_DB_NAME=ai_learning_platform

CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION_NAME=material_chunks

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=
LLM_PROVIDER=gemini
GEMINI_API_KEY=
# Optional: Multiple Gemini API keys for rotation (comma-separated). If set, GEMINI_API_KEYS takes precedence over GEMINI_API_KEY
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-3-flash-preview
MASCOT_CHAT_MODEL=openai/gpt-4o-mini

WHISPER_MODEL=base
WHISPER_LANGUAGE=
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com

UPLOAD_DIR=./storage/uploads
GENERATED_DIR=./storage/generated

CORS_ORIGINS=["http://localhost:3000"]

CHUNK_SIZE=2500
CHUNK_OVERLAP=500
RETRIEVAL_TOP_K=6
