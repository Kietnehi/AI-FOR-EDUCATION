APP_ENV=development
LOG_LEVEL=INFO

MONGO_URI=
MONGO_DB_NAME=

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION_NAME=material_chunks

OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=AIMENTOR
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-3-flash-preview
MASCOT_CHAT_MODEL=openai/gpt-4o-mini
WEB_SEARCH_REFINEMENT_MODEL=openai/gpt-4o-mini

# Cấu hình Tìm kiếm Web
# Google Search: Hỗ trợ cho các mô hình Gemini (gemini-2.5-flash, gemini-3.1-flash-live-preview, v.v.)
# Tự động kích hoạt nếu GEMINI_API_KEY được cấu hình

# Tavily API Key: Dự phòng cho các mô hình không phải Gemini
# Lấy từ: https://app.tavily.com
TAVILY_API_KEY=

UPLOAD_DIR=./storage/uploads
GENERATED_DIR=./storage/generated
IMAGE_CACHE_DIR=./storage/images

USE_S3=false
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=ai-learning-storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

PEXELS_API_KEY=

CORS_ORIGINS=["http://localhost:3000"]

# Auth (Google OAuth + JWT)
GOOGLE_CLIENT_ID=
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=43200
AUTH_COOKIE_NAME=ai_learning_auth_token
AUTH_COOKIE_SECURE=false

CHUNK_SIZE=2500
CHUNK_OVERLAP=500
RETRIEVAL_TOP_K=6
CHAT_MEMORY_TURNS=8
MASCOT_MEMORY_TURNS=10

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
WHISPER_MODEL=base
