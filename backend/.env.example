APP_ENV=development
LOG_LEVEL=INFO

MONGO_URI=
MONGO_DB_NAME=

CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION_NAME=material_chunks

OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=AIMENTOR
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-3-flash-preview
MASCOT_CHAT_MODEL=openai/gpt-4o-mini
WEB_SEARCH_REFINEMENT_MODEL=openai/gpt-4o-mini

# Cấu hình Tìm kiếm Web
# Google Search: Hỗ trợ cho các mô hình Gemini (gemini-2.5-flash, gemini-3.1-flash-live-preview, v.v.)
# Tự động kích hoạt nếu GEMINI_API_KEY được cấu hình

# Tavily API Key: Dự phòng cho các mô hình không phải Gemini
# Lấy từ: https://app.tavily.com
TAVILY_API_KEY=

UPLOAD_DIR=./storage/uploads
GENERATED_DIR=./storage/generated
IMAGE_CACHE_DIR=./storage/images

PEXELS_API_KEY=

CORS_ORIGINS=["http://localhost:3000"]

CHUNK_SIZE=2500
CHUNK_OVERLAP=500
RETRIEVAL_TOP_K=6
CHAT_MEMORY_TURNS=8
MASCOT_MEMORY_TURNS=10

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
WHISPER_MODEL=base
